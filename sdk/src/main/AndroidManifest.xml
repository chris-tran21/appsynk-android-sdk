<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for sending events to the AppSynk API -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required for connectivity-aware delivery and WorkManager network constraints -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Required for reading the Google Advertising ID (GAID). -->
    <!-- Users can opt out in Google Settings > Privacy > Ads -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

    <!--
        Package visibility for the Meta (Facebook / Instagram) Install Referrer content providers.
        Required on Android 11+ (API 30+) so the SDK can resolve and query the FB / FB-Lite / IG
        InstallReferrerProvider for view-through attribution (see prompt 8).
    -->
    <queries>
        <package android:name="com.facebook.katana" />
        <package android:name="com.facebook.lite" />
        <package android:name="com.instagram.android" />
    </queries>

    <!--
        ── Backup exclusion (host-app action required) ──────────────────────────────────────────
        The AppSynk install instance id lives in the `appsynk_id` SharedPreferences. It MUST NOT be
        backed up: Android Auto Backup would restore it across devices / reinstalls, making two
        distinct installs share one id and corrupting attribution.

        This library ships ready-to-use exclusion rules:
          • res/xml/appsynk_backup_rules.xml  (Android 12+,  API 31+)    -> android:dataExtractionRules
          • res/xml/appsynk_full_backup.xml    (Android 6–11, API 23–30) -> android:fullBackupContent

        Add them to YOUR app's <application> tag, or merge the <exclude> rules into your existing
        backup configuration files:

            <application
                android:dataExtractionRules="@xml/appsynk_backup_rules"
                android:fullBackupContent="@xml/appsynk_full_backup">

        (These attributes are intentionally NOT set on the library manifest: a library cannot set
        them without colliding with the host app's own backup configuration during manifest merge.)
    -->

</manifest>
